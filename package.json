{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20 || 22"
  },
  "scripts": {
    "start": "dotenv -e .env -- backstage-cli repo start",
    "build:backend": "yarn workspace backend build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "new": "backstage-cli new"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/e2e-test-utils": "^0.1.2",
    "@playwright/test": "^1.32.3",
    "@types/jest": "^30.0.0",
    "dotenv-cli": "^11.0.0",
    "node-gyp": "^10.0.0",
    "prettier": "^2.3.2",
    "typescript": "~5.8.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "isolated-vm": "5.0.4"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.4.1",
  "dependencies": {
    "@backstage-community/plugin-catalog-backend-module-keycloak": "^3.16.0",
    "@backstage-community/plugin-tech-radar": "^1.13.0",
    "@backstage/backend-common": "^0.25.0",
    "@backstage/plugin-auth-backend": "^0.29.1",
    "@backstage/plugin-auth-react": "^0.1.28",
    "@backstage/plugin-catalog-backend-module-ldap": "^0.12.6",
    "@backstage/plugin-github-actions": "^0.6.16",
    "@backstage/plugin-home": "^0.9.7",
    "@backstage/plugin-home-react": "^0.1.39",
    "@backstage/plugin-search": "^1.7.5",
    "@backstage/plugin-search-react": "^1.11.5",
    "@roadiehq/backstage-plugin-github-pull-requests": "^3.7.0"
  }
}
